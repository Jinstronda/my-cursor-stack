# Simplified Environment Variables
# Copy values to your .env.local for development

# Node environment
NODE_ENV=development

# These are now hardcoded in the application for reliability
# SUPABASE_URL=https://ronbobkftucgcffiqtgu.supabase.co
# SUPABASE_ANON_KEY=eyJhbGci...

# You still need these for advanced features
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database (keep for complex queries if needed)
DATABASE_URL=your_supabase_postgres_connection_string_here

# Service role key (server-side operations)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here